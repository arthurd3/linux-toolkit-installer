#!/usr/bin/env bash
# Mock cc (gcc's generic name) — see the gcc mock.
echo "cc $*" >> "${LTI_TEST_CAPTURE:-/dev/null}"
for a in "$@"; do
    case "$a" in
        --version)    printf '%s\n' "${LTI_MOCK_GCC_VERSION:-cc (GCC) 16.1.1 20260515}"; exit 0 ;;
        -dumpversion) printf '16\n'; exit 0 ;;
    esac
done
out=""; prev=""
for a in "$@"; do [[ $prev == -o ]] && out=$a; prev=$a; done
cat >/dev/null 2>&1 || true
if [[ -n $out ]]; then : > "$out" && chmod +x "$out" 2>/dev/null || true; fi
exit "${LTI_MOCK_CC_RC:-0}"
