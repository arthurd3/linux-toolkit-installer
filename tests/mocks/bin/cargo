#!/usr/bin/env bash
# Mock cargo — capture; `--version` canned; `build` exits LTI_MOCK_CARGO_RC.
echo "cargo $*" >> "${LTI_TEST_CAPTURE:-/dev/null}"
case "${1:-}" in
    --version) printf '%s\n' "${LTI_MOCK_CARGO_VERSION:-cargo 1.96.1 (356927216 2026-06-26)}" ;;
    build)     exit "${LTI_MOCK_CARGO_RC:-0}" ;;
esac
exit 0
